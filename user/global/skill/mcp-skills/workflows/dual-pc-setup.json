{
  "name": "双电脑集群搭建工作流",
  "version": "1.0",
  "description": "从设备发现到集群运行的完整自动化流程",
  "steps": [
    {
      "id": 1,
      "name": "网络扫描",
      "description": "发现局域网中的设备",
      "command": "scan_network.bat",
      "skills": ["network-transfer-skill"],
      "output": "device_list"
    },
    {
      "id": 2,
      "name": "配置双网卡",
      "description": "设置有线和无线网络",
      "command": "configure_dual_network.bat",
      "skills": ["system-config-skill"],
      "depends_on": [1]
    },
    {
      "id": 3,
      "name": "传输文件",
      "description": "高速传输 /python 文件夹",
      "command": "start_high_speed_send.bat",
      "skills": ["network-transfer-skill"],
      "depends_on": [2],
      "parallel": false
    },
    {
      "id": 4,
      "name": "配置目标电脑",
      "description": "在接收端执行系统配置",
      "command": "python configure_target.py",
      "skills": ["system-config-skill"],
      "depends_on": [3],
      "target": "remote"
    },
    {
      "id": 5,
      "name": "安装 EXo",
      "description": "在两台电脑安装 EXo",
      "command": "install-exo.bat",
      "skills": ["exo-cluster-skill"],
      "depends_on": [4],
      "target": "both"
    },
    {
      "id": 6,
      "name": "启动集群",
      "description": "启动 EXo 集群节点",
      "command": "start-cluster.bat",
      "skills": ["exo-cluster-skill"],
      "depends_on": [5],
      "target": "both"
    },
    {
      "id": 7,
      "name": "验证集群",
      "description": "检查集群状态",
      "command": "curl http://localhost:52415/v1/models",
      "skills": ["exo-cluster-skill"],
      "depends_on": [6]
    }
  ],
  "config": {
    "source_ip": "192.168.1.3",
    "target_ip": "192.168.1.10",
    "wired_subnet": "192.168.2.0/24",
    "wireless_subnet": "192.168.1.0/24",
    "transfer_port": 50000,
    "exo_port": 50051
  }
}
