{
  "name": "带通知的文件传输",
  "version": "1.0",
  "description": "传输文件并实时通知双方状态",
  "steps": [
    {
      "id": 1,
      "name": "启动通知服务",
      "description": "在双方启动通知监听",
      "command": "python notification_service.py &",
      "target": "both",
      "background": true
    },
    {
      "id": 2,
      "name": "网络质量检测",
      "description": "测试网络连接质量",
      "command": "python network_speed_test.py",
      "depends_on": [1]
    },
    {
      "id": 3,
      "name": "启动接收端",
      "description": "在目标电脑启动接收服务",
      "command": "python high_speed_receive_v2.py",
      "target": "remote",
      "depends_on": [2],
      "blocking": true
    },
    {
      "id": 4,
      "name": "执行传输",
      "description": "开始高速文件传输",
      "command": "python high_speed_transfer_v2.py",
      "depends_on": [3]
    },
    {
      "id": 5,
      "name": "验证完整性",
      "description": "检查文件传输完整性",
      "command": "python verify_transfer.py",
      "depends_on": [4]
    },
    {
      "id": 6,
      "name": "发送完成通知",
      "description": "通知双方传输完成",
      "command": "python send_notification.py --type transfer_complete",
      "depends_on": [5],
      "target": "both"
    }
  ],
  "config": {
    "source_ip": "192.168.1.3",
    "target_ip": "192.168.1.10",
    "notification_port": 50001,
    "transfer_port": 50000
  }
}
