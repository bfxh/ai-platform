{
  "name": "双电脑集群搭建",
  "version": "2.0",
  "description": "从设备发现到集群运行的完整自动化流程",
  "steps": [
    {
      "id": "discover",
      "name": "设备发现",
      "description": "发现局域网中的设备",
      "skill": "network_transfer",
      "action": "discover",
      "params": {},
      "output": "devices"
    },
    {
      "id": "configure_firewall",
      "name": "配置防火墙",
      "description": "配置防火墙规则",
      "skill": "system_config",
      "action": "configure_exo_node",
      "params": {},
      "depends_on": ["discover"]
    },
    {
      "id": "notify_start",
      "name": "发送开始通知",
      "description": "通知用户开始配置",
      "skill": "notification",
      "action": "notify",
      "params": {
        "title": "集群搭建",
        "message": "开始配置双电脑集群...",
        "type": "info"
      },
      "depends_on": ["configure_firewall"]
    },
    {
      "id": "start_exo_local",
      "name": "启动本地EXo节点",
      "description": "在本机启动EXo服务",
      "skill": "exo_cluster",
      "action": "start_node",
      "params": {},
      "depends_on": ["notify_start"]
    },
    {
      "id": "discover_exo_nodes",
      "name": "发现EXo节点",
      "description": "发现集群中的其他节点",
      "skill": "exo_cluster",
      "action": "discover_nodes",
      "params": {},
      "depends_on": ["start_exo_local"]
    },
    {
      "id": "check_status",
      "name": "检查集群状态",
      "description": "验证集群是否正常运行",
      "skill": "exo_cluster",
      "action": "get_status",
      "params": {},
      "depends_on": ["discover_exo_nodes"]
    },
    {
      "id": "notify_complete",
      "name": "发送完成通知",
      "description": "通知用户配置完成",
      "skill": "notification",
      "action": "notify",
      "params": {
        "title": "集群搭建完成",
        "message": "双电脑集群已成功配置！",
        "type": "success",
        "sound": "complete"
      },
      "depends_on": ["check_status"]
    }
  ],
  "config": {
    "source_ip": "192.168.1.3",
    "target_ip": "192.168.1.10",
    "auto_retry": true,
    "timeout": 600
  }
}
