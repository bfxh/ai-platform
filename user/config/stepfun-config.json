  "usage": {
    "find_software": "python /python/ai.py dev find <keyword>",
    "open_software": "python /python/ai.py dev open <name>",
    "screenshot": "python /python/ai.py eye capture <window_title>",
    "download_github": "python /python/ai.py gh release <repo>",
    "download_file": "python /python/ai.py dl <url>",
    "batch_download": "python /python/ai.py batch <urls_file>",
    "download_queue": "python /python/MCP/download_manager.py queue",
    "video_download": "python /python/ai.py vdl <url>",
    "video_convert": "python /python/ai.py vconvert <input> <output>",
    "video_cut": "python /python/ai.py vcut <input> <output> -s <start> -e <end>",
    "video_compress": "python /python/ai.py vcompress <input> <output>",
    "extract_audio": "python /python/ai.py vextract <input> <output>",
    "create_gif": "python /python/ai.py vgif <input> <output> -s <start> -d <duration>",
    "analyze_video": "python /python/ai.py vanalyze <input>",
    "ue5_create_project": "python /python/ai.py ue5new <name>",
    "ue5_build_project": "python /python/ai.py ue5build <project>",
    "ue5_package_project": "python /python/ai.py ue5pkg <project>",
    "ue5_open_project": "python /python/ai.py ue5open <project>",
    "extract_model": "python /python/ai.py extract <game_path>",
    "code_review": "python /python/ai.py cq report <path>"
  }
}
