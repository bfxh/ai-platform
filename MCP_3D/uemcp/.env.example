# UEMCP Environment Variables
# Copy this file to .env and adjust values for your environment.

# Port the Python listener inside Unreal Engine listens on.
# Default: 8765
UEMCP_LISTENER_PORT=8765

# Absolute path to your Unreal Engine project directory.
# Example: /Users/yourname/Documents/Unreal Projects/MyProject
UE_PROJECT_PATH=

# Enable debug logging. Set to "uemcp:*" to see all MCP debug output,
# or "uemcp:bridge" / "uemcp:server" for targeted logging.
# Leave unset to disable debug logging.
DEBUG=

# Enable verbose Python bridge output inside Unreal Engine.
# Set to "1" to activate, then call restart_listener() in UE console.
UEMCP_DEBUG=
