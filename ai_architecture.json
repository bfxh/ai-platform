  "pipeline": {
    "version": "6.0",
    "enabled": true,
    "description": "TRAE 五阶段强制管道——所有项目必须先通过分析/安全/逆向/深度分析四个阶段，才能进入开发阶段",
    "engine": "core/pipeline_engine.py",
    "phases": {
      "1_analysis": {
        "name": "Preliminary Analysis",
        "module": "core/pipeline/phase_analyzer.py",
        "description": "项目架构扫描、代码语言/框架检测、依赖映射、特性识别",
        "gate_condition": "必须检测到编程语言才能通过"
      },
      "2_security": {
        "name": "Security Audit",
        "module": "core/pipeline/phase_security.py",
        "description": "密钥/Token泄露检测、不安全代码模式扫描、依赖漏洞检查",
        "gate_condition": "CRITICAL级别发现则阻塞"
      },
      "3_reverse": {
        "name": "Reverse Engineering",
        "module": "core/pipeline/phase_reverse.py",
        "description": "许可证检测、开源验证、二进制分析、反编译评估",
        "gate_condition": "专有软件或无法确认许可证则阻塞"
      },
      "4_deep": {
        "name": "Deep Analysis",
        "module": "core/pipeline/phase_deep.py",
        "description": "交叉分析前三个阶段结果、风险重评估、可行性判断",
        "gate_condition": "所有阻断项清除后通过"
      },
      "5_dev": {
        "name": "Development",
        "module": "core/pipeline/phase_dev.py",
        "description": "仅在前四个阶段通过后执行：编码、建模、测试、部署",
        "gate_condition": "Phase 1-4 必须全部通过"
      }
    },
    "enforcement": {
      "strict_mode": true,
      "skip_phases_on_opensource_mit": false,
      "block_on_critical_security": true,
      "block_on_proprietary": true,
      "require_license_phase": true,
      "max_phase_duration_seconds": 300
    },
    "integration": {
      "brain_memory": true,
      "event_bridge": true,
      "report_path": "storage/data/pipeline_reports/"
    }
  },
