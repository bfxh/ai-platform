{
  "name": "memory_mcp",
  "version": "1.0",
  "description": "记忆 MCP 服务器 - 提供 remember/recall API 维护会话记忆",
  "category": "Tools",
  "author": "GSTACK",
  "created": "2026-04-19",
  "commands": {
    "remember": "保存记忆",
    "recall": "回忆记忆",
