{
  "workflow_name": "terraria-gpu-optimization-workflow",
  "version": "2.0.0",
  "description": "泰拉瑞亚GPU粒子优化完整工作流 - 从分析到部署的全自动化流程",
  "author": "AI Assistant",
  
  "trigger": {
    "type": "manual",
    "conditions": []
  },
  
  "variables": {
    "mod_name": "CalamityMod",
    "mod_path": "%DEV_DIR%\\泰拉瑞亚\\模组源码\\CalamityMod",
    "output_path": "%DEV_DIR%\\泰拉瑞亚",
    "max_particles": 50000,
    "enable_gpu": true,
    "enable_compatibility": true,
    "run_tests": true
  },
  
  "stages": [
    {
      "id": "stage_1_analysis",
      "name": "阶段1: 模组分析",
      "description": "分析模组结构和粒子系统",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-mod-analyzer",
          "action": "analyze_structure",
          "inputs": {
            "mod_path": "${mod_path}"
          },
          "outputs": {
            "structure_report": "structure_report.json"
          }
        },
        {
          "skill": "terraria-mod-analyzer",
          "action": "analyze_particles",
          "inputs": {
            "mod_path": "${mod_path}"
          },
          "outputs": {
            "particle_analysis": "particle_analysis.json"
          }
        },
        {
          "skill": "terraria-mod-analyzer",
          "action": "identify_bottlenecks",
          "inputs": {
            "mod_path": "${mod_path}"
          },
          "outputs": {
            "bottlenecks": "bottlenecks.json"
          }
        }
      ]
    },
    
    {
      "id": "stage_2_gpu_optimization",
      "name": "阶段2: GPU优化",
      "description": "实施GPU粒子系统优化",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-gpu-particle-optimizer",
          "action": "generate_shaders",
          "inputs": {
            "mod_path": "${mod_path}",
            "enable_compute_shaders": true
          },
          "outputs": {
            "shader_files": "shaders/"
          }
        },
        {
          "skill": "terraria-gpu-particle-optimizer",
          "action": "create_particle_system",
          "inputs": {
            "mod_path": "${mod_path}",
            "max_particles": "${max_particles}"
          },
          "outputs": {
            "system_files": "systems/"
          }
        },
        {
          "skill": "terraria-gpu-particle-optimizer",
          "action": "add_config",
          "inputs": {
            "mod_path": "${mod_path}"
          },
          "outputs": {
            "config_files": "config/"
          }
        }
      ]
    },
    
    {
      "id": "stage_3_compatibility",
      "name": "阶段3: 兼容性集成",
      "description": "添加模组兼容性支持",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-mod-compatibility",
          "action": "setup",
          "inputs": {
            "target_mods": ["CalamityMod", "ThoriumMod", "FargoSouls", "SpiritMod"],
            "auto_convert": true
          },
          "outputs": {
            "compatibility_layer": "compatibility/"
          }
        },
        {
          "skill": "terraria-mod-compatibility",
          "action": "generate_api",
          "inputs": {
            "mod_path": "${mod_path}"
          },
          "outputs": {
            "api_files": "api/"
          }
        }
      ]
    },
    
    {
      "id": "stage_4_build_test",
      "name": "阶段4: 编译测试",
      "description": "编译项目并运行测试",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-build-test",
          "action": "build",
          "inputs": {
            "project_path": "${mod_path}\\${mod_name}.csproj",
            "build_config": "Release"
          },
          "outputs": {
            "build_result": "build_result.json"
          }
        },
        {
          "skill": "terraria-build-test",
          "action": "test",
          "inputs": {
            "project_path": "${mod_path}",
            "test_categories": ["unit", "performance", "compatibility"]
          },
          "outputs": {
            "test_results": "test_results.json"
          }
        },
        {
          "skill": "terraria-build-test",
          "action": "benchmark",
          "inputs": {
            "particle_count": "${max_particles}"
          },
          "outputs": {
            "benchmark_results": "benchmark.json"
          }
        }
      ]
    },
    
    {
      "id": "stage_5_documentation",
      "name": "阶段5: 文档生成",
      "description": "生成完整的优化文档",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-doc-generator",
          "action": "generate_optimization_guide",
          "inputs": {
            "mod_name": "${mod_name}",
            "output_path": "${output_path}"
          },
          "outputs": {
            "guide_file": "优化指南.md"
          }
        },
        {
          "skill": "terraria-doc-generator",
          "action": "generate_api_reference",
          "inputs": {
            "mod_name": "${mod_name}",
            "output_path": "${output_path}"
          },
          "outputs": {
            "api_doc": "API参考.md"
          }
        },
        {
          "skill": "terraria-doc-generator",
          "action": "generate_compatibility_guide",
          "inputs": {
            "mod_name": "${mod_name}",
            "output_path": "${output_path}"
          },
          "outputs": {
            "compat_doc": "兼容性指南.md"
          }
        }
      ]
    },
    
    {
      "id": "stage_6_deployment",
      "name": "阶段6: 部署",
      "description": "部署优化后的模组",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-build-test",
          "action": "deploy",
          "inputs": {
            "mod_name": "${mod_name}",
            "deploy_path": "%USERPROFILE%\Documents\My Games\Terraria\tModLoader\Mods"
          },
          "outputs": {
            "deploy_result": "deploy_result.json"
          }
        }
      ]
    },
    {
      "id": "stage_7_steam_upload",
      "name": "阶段7: Steam上传",
      "description": "上传到Steam Workshop",
      "parallel": false,
      "steps": [
        {
          "skill": "terraria-steam-uploader",
          "action": "prepare",
          "inputs": {
            "mod_name": "${mod_name}",
            "mod_path": "${mod_path}",
            "output_path": "${output_path}\发布"
          },
          "outputs": {
            "prepare_result": "prepare_result.json"
          }
        },
        {
          "skill": "terraria-steam-uploader",
          "action": "build",
          "inputs": {
            "mod_name": "${mod_name}"
          },
          "outputs": {
            "build_result": "steam_build_result.json"
          }
        },
        {
          "skill": "terraria-steam-uploader",
          "action": "package",
          "inputs": {
            "mod_name": "${mod_name}",
            "output_path": "${output_path}\发布"
          },
          "outputs": {
            "package_result": "package_result.json"
          }
        },
        {
          "skill": "terraria-steam-uploader",
          "action": "upload",
          "inputs": {
            "mod_name": "${mod_name}",
            "changelog": "GPU粒子系统优化，性能提升10-50倍"
          },
          "outputs": {
            "upload_result": "upload_result.json"
          }
        },
        {
          "skill": "terraria-steam-uploader",
          "action": "verify",
          "inputs": {
            "workshop_item_id": "${workshop_item_id}"
          },
          "outputs": {
            "verify_result": "verify_result.json"
          }
        },
        {
          "skill": "terraria-steam-uploader",
          "action": "report",
          "inputs": {
            "output": "${output_path}\上传报告.md"
          },
          "outputs": {
            "report_file": "upload_report.md"
          }
        }
      ]
    }
  ],
  
  "error_handling": {
    "on_failure": "stop",
    "retry_count": 3,
    "retry_delay": 5,
    "notification": {
      "enabled": true,
      "on_success": true,
      "on_failure": true
    }
  },
  
  "artifacts": {
    "save_intermediate": true,
    "output_directory": "${output_path}\\优化结果",
    "include": [
      "*.log",
      "*.json",
      "*.md",
      "*.cs",
      "*.fx"
    ]
  },
  
  "notifications": {
    "on_start": {
      "message": "开始GPU粒子优化工作流",
      "channels": ["console", "log"]
    },
    "on_stage_complete": {
      "message": "阶段 {stage_name} 完成",
      "channels": ["console", "log"]
    },
    "on_complete": {
      "message": "GPU粒子优化工作流完成！性能提升10-50倍",
      "channels": ["console", "log", "notification"]
    },
    "on_error": {
      "message": "工作流错误: {error_message}",
      "channels": ["console", "log", "notification"]
    }
  },
  
  "metadata": {
    "created": "2026-04-05",
    "updated": "2026-04-05",
    "estimated_duration": "20-40分钟",
    "required_skills": [
      "terraria-gpu-particle-optimizer",
      "terraria-mod-compatibility",
      "terraria-build-test",
      "terraria-doc-generator",
      "terraria-steam-uploader"
    ]
  }
}
